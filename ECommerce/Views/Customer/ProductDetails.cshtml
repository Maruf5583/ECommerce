@model List<ECommerce.Models.Product>
@using System.Globalization
@{
    ViewData["Title"] = "Product Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .pd-wrap { background: #ffffff; padding: 30px 0 60px; min-height: 70vh; }
    .breadcrumb-bar { font-size: 13px; color: #888; margin-bottom: 18px; }
    .breadcrumb-bar a { color: #888; text-decoration: none; }
    .breadcrumb-bar a:hover { color: #e8ab27; }

    .pd-card {
        background: #fff;
        border-radius: 8px;
        box-shadow: 2px;
        padding: 32px;
    }

    /* Image */
    .pd-img-main {
        width: 100%;
        height: 320px;
        object-fit: contain;
        border: 1px solid #eee;
        border-radius: 6px;
        padding: 12px;
        background: #fafafa;
    }

    /* Info */
    .pd-name {
        font-size: 22px;
        font-weight: 700;
        color: #1a1a6e;
        margin-bottom: 14px;
    }
    .pd-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 18px;
    }
    .pd-meta-item {
        background: #ffffff;
        border: 1px solid #e8e8e8;
        border-radius: 4px;
        padding: 4px 12px;
        font-size: 13px;
        color: #444;
    }
    .pd-meta-item strong { color: #222; }
    .in-stock { color: #2e7d32; font-weight: 700; }

    /* Price */
    .pd-price-row {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
    }
    .pd-price {
        font-size: 26px;
        font-weight: 700;
        color: #222;
    }
    .pd-price-label {
        font-size: 13px;
        color: #999;
    }

    /* Description */
    .pd-desc-title {
        font-size: 15px;
        font-weight: 700;
        color: #222;
        margin-bottom: 10px;
        margin-top: 18px;
    }
    .pd-desc {
        font-size: 14px;
        color: #555;
        line-height: 1.7;
        padding-left: 0;
    }
    .pd-desc li {
        padding: 3px 0;
        border-bottom: 1px solid #f5f5f5;
        list-style: none;
    }
    .pd-desc li::before {
        content: "▸ ";
        color: #e8ab27;
        font-size: 12px;
    }

    /* Star Points */
    .star-points {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: #fff8e1;
        border-radius: 6px;
        padding: 8px 16px;
        margin: 16px 0;
    }
    .star-icon {
        width: 32px;
        height: 32px;
        background: #e8ab27;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 16px;
    }
    .star-points-text { font-size: 15px; font-weight: 600; color: #333; }
    .star-points-label { font-size: 13px; color: #888; }

    /* Payment Options */
    .payment-title {
        font-size: 15px;
        font-weight: 700;
        color: #222;
        margin-bottom: 12px;
    }
    .payment-options {
        display: flex;
        gap: 12px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }
    .payment-option {
        flex: 1;
        min-width: 160px;
        border: 2px solid #ddd;
        border-radius: 6px;
        padding: 14px 16px;
        cursor: pointer;
        transition: border-color 0.2s;
    }
    .payment-option.active { border-color: #1a1a6e; }
    .payment-option-price {
        font-size: 18px;
        font-weight: 700;
        color: #222;
    }
    .payment-option-label {
        font-size: 12px;
        color: #888;
        margin-top: 2px;
    }

    /* Qty + Buttons */
    .action-row {
        display: flex;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
        margin-top: 20px;
        padding-top: 20px;
        border-top: 1px solid #f0f0f0;
    }
    .qty-wrap {
        display: flex;
        align-items: center;
        border: 1px solid #ddd;
        border-radius: 4px;
        overflow: hidden;
    }
    .qty-btn {
        width: 38px;
        height: 42px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f5f5f5;
        color: #444;
        font-size: 18px;
        font-weight: 600;
        border: none;
        cursor: pointer;
        transition: background 0.15s;
        text-decoration: none;
    }
    .qty-btn:hover { background: #e8ab27; color: #fff; }
    .qty-num {
        width: 48px;
        text-align: center;
        font-size: 15px;
        font-weight: 700;
        color: #222;
        border-left: 1px solid #ddd;
        border-right: 1px solid #ddd;
        height: 42px;
        line-height: 42px;
    }
    .btn-cart {
        flex: 1;
        padding: 11px 20px;
        background: #fff;
        color: #1a1a6e;
        border: 2px solid #1a1a6e;
        border-radius: 4px;
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
        text-align: center;
        transition: all 0.2s;
        letter-spacing: 0.3px;
    }
    .btn-cart:hover { background: #1a1a6e; color: #fff; }
    .btn-buynow {
        flex: 1;
        padding: 11px 20px;
        background: #1a1a6e;
        color: #fff;
        border: 2px solid #1a1a6e;
        border-radius: 4px;
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
        text-align: center;
        transition: all 0.2s;
        letter-spacing: 0.3px;
    }
    .btn-buynow:hover { background: #e8ab27; border-color: #e8ab27; color: #fff; }

    .btn-back {
        display: inline-block;
        margin-top: 20px;
        padding: 10px 22px;
        background: #fff;
        color: #222;
        border: 1px solid #ddd;
        border-radius: 4px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s;
    }
    .btn-back:hover { background: #e8ab27; color: #fff; border-color: #e8ab27; }
</style>

<div class="pd-wrap">
    <div class="container">

        @if (TempData["OrderSuccess"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mb-3" style="font-size:14px; border-radius:4px;">
                @TempData["OrderSuccess"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["message"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mb-3" style="font-size:14px; border-radius:4px;">
                @TempData["message"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="breadcrumb-bar">
            <a href="/Customer/Index">🏠 Home</a> /
            <a href="/Customer/FetchAllProduct">Products</a> /
            Product Details
        </div>

        @foreach (var product in Model)
        {
            <div class="pd-card">
                <div class="row g-4">

                    <!-- Left: Image -->
                    <div class="col-md-5">
                        <img src="~/ProductImage/@product.Image"
                             class="pd-img-main"
                             alt="@product.Name" />
                    </div>

                    <!-- Right: Info -->
                    <div class="col-md-7">
                        <div class="pd-name">@product.Name</div>

                        <!-- Meta Info -->
                        <div class="pd-meta">
                            <span class="pd-meta-item">Price: <strong>৳ @product.Price</strong></span>
                            <span class="pd-meta-item">Regular Price: <strong>৳ @product.Price</strong></span>
                            <span class="pd-meta-item">Status: <strong class="in-stock">In Stock</strong></span>
                        </div>

                        <!-- Description -->
                        @if (!string.IsNullOrEmpty(product.Description))
                        {
                            <div class="pd-desc-title">Key Features</div>
                            <ul class="pd-desc">
                                @foreach (var line in product.Description.Split('\n'))
                                {
                                    if (!string.IsNullOrWhiteSpace(line))
                                    {
                                        <li>@line</li>
                                    }
                                }
                            </ul>
                        }

                        <!-- Star Points -->
                        <div class="star-points">
                            <div class="star-icon">⭐</div>
                            <div>
                                <div class="star-points-text">Earn Reward Points</div>
                                <div class="star-points-label">Purchase this product to earn points</div>
                            </div>
                        </div>

                        <!-- Payment Options -->
                        <div class="payment-title">Payment Options</div>
                        <div class="payment-options">
                            <div class="payment-option active">
                                <div style="display:flex; align-items:center; gap:8px; margin-bottom:4px;">
                                    <div style="width:16px; height:16px; border-radius:50%; border:2px solid #1a1a6e; display:flex; align-items:center; justify-content:center;">
                                        <div style="width:8px; height:8px; border-radius:50%; background:#1a1a6e;"></div>
                                    </div>
                                    <div class="payment-option-price">৳ @product.Price</div>
                                </div>
                                <div class="payment-option-label">Cash Discount Price</div>
                                <div class="payment-option-label">Online / Cash Payment</div>
                            </div>
                            <div class="payment-option">
                                <div style="display:flex; align-items:center; gap:8px; margin-bottom:4px;">
                                    <div style="width:16px; height:16px; border-radius:50%; border:2px solid #ddd;"></div>
                                    <div class="payment-option-price" style="font-size:15px;">EMI Available</div>
                                </div>
                                <div class="payment-option-label">Regular Price: ৳ @product.Price</div>
                                <div class="payment-option-label">0% EMI up to 12 Months</div>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="action-row">
                            <div class="qty-wrap">
                                <button class="qty-btn" onclick="changeQty(-1)">−</button>
                                <span class="qty-num" id="qty">1</span>
                                <button class="qty-btn" onclick="changeQty(1)">+</button>
                            </div>
                            <a href="@Url.Action("AddToCart", "Customer", new { id = product.Id })"
                               class="btn-cart">
                                 Add to Cart
                            </a>
                            <a href="@Url.Action("BuyNow", "Customer", new { id = product.Id })"
                               class="btn-buynow">
                                ⚡ Buy Now
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }

        <a href="@Url.Action("FetchAllProduct", "Customer")" class="btn-back">
            ⬅ Back to Products
        </a>

    </div>
</div>

<script>
    function changeQty(val) {
        var el = document.getElementById('qty');
        var current = parseInt(el.innerText);
        var next = current + val;
        if (next >= 1) el.innerText = next;
    }
</script>