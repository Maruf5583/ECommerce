@using ECommerce.Models
@model List<Customer>

<div class="container-fluid px-4">
    <h2 class="mt-4 text-center text-uppercase" style="letter-spacing:4px">All Customer</h2>
</div>

<div class="container mt-4">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Customer List</h5>
        </div>

        <div class="card-body">

            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle text-center">
                    <thead class="table-dark">
                        <tr>
                            <th>Customer Id</th>
                            <th>Customer Name</th>
                            <th>Customer Phone</th>
                            <th>Customer Country</th>
                            <th>Customer City</th>
                            <th>Customer Address</th>
                            <th>Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var cust in Model)
                        {
                            <tr>
                                <td>@cust.Id</td>
                                <td class="fw-semibold">@cust.Name</td>
                                <td>@cust.Phone</td>
                                <td>@cust.Country</td>
                                <td>@cust.City</td>
                                <td>@cust.Address</td>
                                <td>
                                    <a href="@Url.Action("CustomerDetails", "Admin", new { id = cust.Id })" class="btn btn-primary">Deatials</a>
                                    <a href="@Url.Action("CustomerUpdate", "Admin", new { id = cust.Id })" class="btn btn-warning">Update</a>
                                    <a href="@Url.Action("CustomerDelete", "Admin", new { id = cust.Id })" class="btn btn-danger">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>