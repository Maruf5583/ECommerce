@model Cart
<div class="container-fluid px-4">
    <h2 class="mt-4 text-center text-uppercase" style="letter-spacing:4px">Update Cart Status</h2>
</div>
<div class="row">
    <div class="col-md-2"></div>

    <div class="col-md-8">
        <form method="post" asp-action="UpdateCart" asp-controller="Admin">
            <input type="hidden" name="Id" value="@Model.Id">
            <input type="hidden" name="ProductId" value="@Model.ProductId">
            <input type="hidden" name="CustomerId" value="@Model.CustomerId">
            <input type="hidden" name="ProductQuantity" value="@Model.ProductQuantity">
            <select name="cartStatus" class="form-select my-3">
                <option value="0">Pending</option>
                <option value="1">Order</option>
            </select>
            <input type="submit" value="Update Cart" class="form-control my-3 btn btn-primary"/>
        </form>
        
        <a asp-action="FetchCart" asp-controller="Admin" class="btn btn-secondary my-3">Back to List</a>


    </div>

    <div class="col-md-2"></div>
</div>

