@model List<Category>

<div class="container-fluid px-4">
    <h2 class="mt-4 text-center text-uppercase" style="letter-spacing:4px">All Category</h2>
</div>
<a asp-action="AddCategory" asp-controller="Admin" class="btn btn-primary mt-2">Add New Category</a>

<div class="container mt-4">
    
    <div class="card shadow-lg border-0">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Customer List</h5>
        </div>

        <div class="card-body">

            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle text-center">
                    <thead class="table-dark">
                        <tr>
                            <th>Category Id</th>
                            <th>Category Name</th>
                            
                            <th>Options</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var cat in Model)
                        {
                            <tr>
                                <td>@cat.Id</td>
                                <td>@cat.Name</td>
                                <td>
                                    <a href="@Url.Action("UpdateCategory", "Admin", new { id = cat.Id })" class="btn btn-warning">Update</a>
                                    <a href="@Url.Action("DeleteCategoryConfirmed", "Admin", new { id = cat.Id })" class="btn btn-danger">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>
