@model List<Cart>

<div class="container-fluid px-4">
    <h2 class="mt-4 text-center text-uppercase" style="letter-spacing:4px">All Cart Details</h2>
</div>


<div class="container mt-4">

    <div class="card shadow-lg border-0">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Customer Cart List</h5>
        </div>

        <div class="card-body">

            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle text-center">
                    <thead class="table-dark">
                        <tr>
                            <th>Product Name</th>
                            <th>Customer Name</th>
                            <th>Product Quantity </th>
                            <th>Status </th>



                            <th>Options</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var cat in Model)
                        {
                            <tr>
                               
                                <td>@cat.products.Name</td>
                                <td>@cat.customers.Name</td>
                                <td>@cat.ProductQuantity</td>
                                <td>@cat.CartStatus</td>

                                <td>
                                    <a href="@Url.Action("UpdateCart", "Admin", new { id = cat.Id })" class="btn btn-primary">Update</a>
                                    <a href="@Url.Action("DeleteCartConfirmed", "Admin", new { id = cat.Id })" class="btn btn-danger">Delete</a>
                                </td>
                               
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>

