@model List<Product>

<div class="container-fluid px-4">
    <h2 class="mt-4 text-center text-uppercase" style="letter-spacing:4px">All Product</h2>
</div>
<a asp-action="AddProduct" asp-controller="Admin" class="btn btn-primary mt-2">Add New Product</a>

<div class="container mt-4">

    <div class="card shadow-lg border-0">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Customer List</h5>
        </div>

        <div class="card-body">

            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle text-center">
                    <thead class="table-dark">
                        <tr>
                            <th>Product Image</th>
                            <th>Product Name</th>
                            <th>Product Price </th>
                        


                            <th>Options</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var pro in Model)
                        {
                            <tr>
                                <td><img src="@("~/ProductImage/" + pro.Image)" asp-append-version="true" height="40px" width="40px"></img></td>
                                <td>@pro.Name</td>
                                <td>@pro.Price</td>
                               
                                <td>
                                    <a href="@Url.Action("ProductDetails", "Admin", new { id = pro.Id })" class="btn btn-primary">Deatials</a>
                                    <a href="@Url.Action("ProductUpdate", "Admin", new { id = pro.Id })" class="btn btn-warning">Update</a>
                                    <a href="@Url.Action("DeleteProductConfirmed", "Admin", new { id = pro.Id })" class="btn btn-danger">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>
