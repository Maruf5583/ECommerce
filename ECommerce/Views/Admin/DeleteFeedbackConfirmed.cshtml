@model Feedback
<div class="row">
    <div class="col-md-2"></div>
    <div class="col-md-8">
        <h2 class="text-danger my-4">Delete Feedback</h2>
        <p class="text-muted">Are you sure you want to delete this Feedback?</p>

        <form method="post" asp-action="DeleteFeedback" asp-controller="Admin">
            <input type="hidden" name="Id" value="@Model.Id" />
            <div>
                <div class="form-control my-3 bg-light">
                    <strong>User Name:</strong> @Model.Name
                </div>
                <div class="form-control my-3 bg-light">
                    <strong>Feedback Message:</strong> @Model.Message
                </div>
                
            </div>
            <button type="submit" class="btn btn-danger my-3">Delete</button>
            <a asp-action="FetchFeedback" asp-controller="Admin" class="btn btn-secondary my-3">Back to List</a>
        </form>

    </div>
</div>
