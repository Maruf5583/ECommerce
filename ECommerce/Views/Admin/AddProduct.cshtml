
<div class="container-fluid px-4">
    <h2 class="mt-4 text-center text-uppercase" style="letter-spacing:4px">Add New Product</h2>
    <div class="row">
        <div class="col-md-2"></div>
        <div class="col-md-8">
            <form method="post" asp-action="AddProduct" enctype="multipart/form-data">
                <input type="text" name="Name" placeholder="Enter Product Name" class="form-control my-3" />
                <input type="text" name="Price" placeholder="Enter Product Price" class="form-control my-3" />
                <input type="text" name="Description" placeholder="Enter Product Description" class="form-control my-3" />
                <input type="file" name="Image" class="form-control my-3" />
                @await Html.PartialAsync("~/Views/Shared/_CategoryDropdown.cshtml", ViewData["category"] as IEnumerable<ECommerce.Models.Category>)

                <input type="submit" value="Add Product" class="form-control my-3 btn btn-primary" />
            </form>
        </div>
        <div class="col-md-2"></div>
    </div>
</div>